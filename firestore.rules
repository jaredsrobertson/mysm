rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rooms: Simpler rules that work with our data model
    match /rooms/{roomCode} {
      // Allow authenticated users to read any room (needed to check if exists)
      allow read: if request.auth != null;
      
      // Allow creating a room if user is authenticated and adding themselves
      allow create: if request.auth != null 
                    && request.auth.uid in request.resource.data.members;
      
      // Allow updating room if user is a member (for lastActivity, etc)
      allow update: if request.auth != null 
                    && (request.auth.uid in resource.data.members
                        || request.auth.uid in request.resource.data.members);

      // Messages subcollection - simplified rules
      match /messages/{msgId} {
        // Allow read/write if authenticated (we trust our app logic)
        // The parent room security provides the main protection
        allow read: if request.auth != null;
        allow create: if request.auth != null 
                      && request.resource.data.from == request.auth.uid;
      }
    }
  }
}