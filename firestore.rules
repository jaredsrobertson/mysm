rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rooms
    match /rooms/{roomCode} {
      // Allow authenticated users to read any room (needed to check if room exists when joining)
      allow read: if request.auth != null;
      
      // Allow creating a room if user is authenticated and adding themselves
      allow create: if request.auth != null 
                    && request.auth.uid in request.resource.data.members;
      
      // Allow updating room if user is already a member OR is joining (members array includes them in new data)
      allow update: if request.auth != null 
                    && (request.auth.uid in resource.data.members
                        || request.auth.uid in request.resource.data.members);

      // Allow members to delete rooms they belong to
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.members;

      // Messages subcollection - only room members can read/write
      match /messages/{msgId} {
        // Only room members can read messages
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomCode)).data.members;
        
        // Only room members can create messages, and must set 'from' to their own UID
        allow create: if request.auth != null 
                      && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomCode)).data.members
                      && request.resource.data.from == request.auth.uid;
      }
    }
  }
}
